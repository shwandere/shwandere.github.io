---
layout: null
---
{
  "posts": [
    {% for post in site.posts %}
    {
      "title": "{{ post.title | escape }}",
      "excerpt": "{{ post.excerpt | strip_html | strip_newlines | escape }}",
      "publishDate": "{{ post.date | date_to_string }}",
      "url": "{{ site.url }}{{ post.url }}",
      "tags": "{{ post.tags | join: ' ' }}"
    }{% if forloop.last == false %},{% endif %}
    {% endfor %}
  ]
}
